{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:5000"
      }
    }
  },
  "Swagger": {
    "Enabled": true
  },

  "ConnectionStrings": {
    "SqlServer": "Server=localhost;Database=tot_db;User Id=YOUR_USER;Password=YOUR_PASSWORD;TrustServerCertificate=True",
    "PostgreSql": "Host=localhost;Database=tot_db;Username=YOUR_USERNAME;Password=YOUR_PASSWORD",
    "FilesFoldersConnection": "Host=localhost;Database=tot_files_db;Username=YOUR_USERNAME;Password=YOUR_PASSWORD",
    "MySql": "Server=localhost;Database=tot_db;Uid=YOUR_UID;Pwd=YOUR_PWD",
    "MongoDb": "mongodb://YOUR_USER:YOUR_PASSWORD@localhost:27017"
  },
  "Firebase": {
    "JsonFilePath": "firebase-adminsdk.sample.json",
    "ProjectId": "YOUR_PROJECT_ID",
    "DatabaseId": "(default)",
    "StorageBucket": "YOUR_STORAGE_BUCKET"
  },
  "Cqrs": {
    "Redis": "localhost:6379,defaultDatabase=0,password=YOUR_PASSWORD,abortConnect=false"
  },
  "Session": {
    "Redis": "localhost:6379,defaultDatabase=0,password=YOUR_PASSWORD,abortConnect=false"
  },
  "Auth": {
    "Jwt": {
      "Secret": "YOUR_JWT_SECRET",
      "RsaPrivateKey": "-----BEGIN PRIVATE KEY-----\nYOUR_RSA_PRIVATE_KEY\n-----END PRIVATE KEY-----",

      "Kid": "YOUR_KID",
      "Algorithm": "RS256",
      "Issuer": "TreeOfThought.BE",
      "Audience": "TreeOfThought.FE",
      "ExpiryMinutes": 60,
      "IsOidc": true,
      "Authority": "http://localhost:5000"
    }
  },
  "Oidc": {
    "OidcLoginUiUrl": "/admin/auth/login",
    "PostgreSql": "Host=localhost;Database=tot_db;Username=YOUR_USERNAME;Password=YOUR_PASSWORD",
    "Redis": "localhost:6379,defaultDatabase=0,password=YOUR_PASSWORD,abortConnect=false",
    "Admin": {
      "Username": "admin",
      "Password": "YOUR_ADMIN_PASSWORD",
      "Email": "admin@example.com"
    }
  }
}