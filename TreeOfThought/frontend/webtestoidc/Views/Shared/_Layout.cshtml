<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - WebTestOidc</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">WebTestOidc</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Secure">Secure</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Claims">Claims</a>
                            </li>
                        }
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                        </li>
                    </ul>
                    <ul class="navbar-nav">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            var username = User.Identity?.Name ?? User.FindFirst("preferred_username")?.Value ?? "User";
                            var fullName = User.FindFirst("name")?.Value ?? username;
                            var pictureUrl = User.FindFirst("picture")?.Value;
                            var email = User.FindFirst("email")?.Value ?? "";
                            var initials = string.IsNullOrEmpty(fullName) ? "U" : fullName.Substring(0, 1).ToUpper();

                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle d-flex align-items-center gap-2 py-1" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false" style="border-radius: 8px; transition: all 0.2s;">
                                    @if (!string.IsNullOrEmpty(pictureUrl))
                                    {
                                        <img src="@pictureUrl" class="rounded-circle border border-2 border-primary" style="width: 32px; height: 32px; object-fit: cover;" alt="Avatar" />
                                    }
                                    else
                                    {
                                        <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center fw-bold shadow-sm" style="width: 32px; height: 32px; font-size: 14px;">
                                            @initials
                                        </div>
                                    }
                                    <span class="fw-semibold text-dark d-none d-md-inline">@fullName</span>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end shadow border-0 p-2 mt-2" aria-labelledby="userDropdown" style="min-width: 240px; border-radius: 12px; background: rgba(255, 255, 255, 0.95); backdrop-filter: blur(8px);">
                                    <li class="px-3 py-2.5">
                                        <div class="d-flex flex-column">
                                            <span class="fw-bold text-dark text-truncate">@fullName</span>
                                            <span class="small text-muted text-truncate">@@@username</span>
                                            @if (!string.IsNullOrEmpty(email))
                                            {
                                                <span class="small text-muted text-truncate mt-0.5"><i class="bi bi-envelope me-1"></i>@email</span>
                                            }
                                        </div>
                                    </li>
                                    <li><hr class="dropdown-divider my-2"></li>
                                    <li>
                                        <a class="dropdown-item d-flex align-items-center gap-2 py-2" asp-controller="Home" asp-action="Secure" style="border-radius: 6px;">
                                            <i class="bi bi-shield-lock-fill text-primary"></i>
                                            <span>Vùng bảo mật</span>
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item d-flex align-items-center gap-2 py-2" asp-controller="Home" asp-action="Claims" style="border-radius: 6px;">
                                            <i class="bi bi-list-ul text-secondary"></i>
                                            <span>Xem Claims</span>
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider my-2"></li>
                                    <li>
                                        <a class="dropdown-item d-flex align-items-center gap-2 py-2 text-danger" asp-controller="Home" asp-action="Logout" style="border-radius: 6px;">
                                            <i class="bi bi-box-arrow-right"></i>
                                            <span>Đăng xuất SSO</span>
                                        </a>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link btn btn-primary text-white px-3 py-1.5 d-flex align-items-center gap-2 fw-semibold shadow-sm" asp-controller="Home" asp-action="Login" style="border-radius: 8px; transition: all 0.2s;">
                                    <i class="bi bi-key-fill"></i>
                                    <span>Đăng nhập SSO</span>
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - WebTestOidc - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
