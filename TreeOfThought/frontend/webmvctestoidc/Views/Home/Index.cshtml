@model IEnumerable<WebMvcTestOidc.Data.AuditLog>
@{
    ViewData["Title"] = "OIDC SSO Portal";
}

<div class="container py-5 animate-fade-in">
    <div class="row justify-content-center">
        <div class="col-md-8 text-center">
            <h1 class="display-4">OIDC Test Portal</h1>
            <p class="lead text-secondary mb-5">Hệ thống kiểm tra xác thực tập trung và Single Sign-On cho hệ sinh thái Tree of Thought.</p>

            @if (User.Identity?.IsAuthenticated == true)
            {
                <div class="card p-4 shadow-lg border-0 mb-5">
                    <div class="card-body">
                        <div class="mb-4">
                            <i class="bi bi-person-check-fill text-success" style="font-size: 3rem;"></i>
                        </div>
                        <h3 class="fw-bold">Xin chào, @User.Identity.Name!</h3>
                        <p class="text-muted">Bạn đã xác thực thành công qua OpenID Connect.</p>
                        
                        <div class="d-flex justify-content-center gap-3 mt-4">
                            <a asp-action="Secure" class="btn btn-primary px-4">
                                <i class="bi bi-shield-lock-fill me-2"></i>Vùng bảo mật
                            </a>
                            <a asp-action="Claims" class="btn btn-outline-primary px-4">
                                <i class="bi bi-list-ul me-2"></i>Xem Claims
                            </a>
                            <a asp-action="Logout" class="btn btn-outline-danger px-4">
                                <i class="bi bi-box-arrow-right me-2"></i>Đăng xuất
                            </a>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <div class="card p-5 shadow-lg border-0 mb-5">
                    <div class="card-body">
                        <div class="mb-4">
                            <i class="bi bi-shield-slash text-warning" style="font-size: 3rem;"></i>
                        </div>
                        <h3 class="fw-bold mb-3">Bạn chưa đăng nhập</h3>
                        <p class="text-muted mb-4">Để truy cập các tài nguyên bảo mật, vui lòng đăng nhập bằng tài khoản SSO của hệ thống.</p>
                        
                        <a asp-action="Login" class="btn btn-primary btn-lg px-5 py-3 fw-bold">
                            <i class="bi bi-key-fill me-2"></i>Đăng nhập bằng SSO
                        </a>
                    </div>
                </div>
            }

            <div class="card bg-white p-4 text-start border-0 shadow-sm mb-4">
                <h5 class="fw-bold mb-3 text-primary"><i class="bi bi-info-circle-fill me-2"></i>Hướng dẫn kiểm tra SSO</h5>
                <div class="row">
                    <div class="col-md-6">
                        <p class="small text-secondary mb-2 fw-bold text-uppercase">Bước 1: Đăng nhập Backend</p>
                        <p class="small">Truy cập <a href="http://localhost:5000" target="_blank" class="text-decoration-none">Backend Portal</a> và đăng nhập với <code>admin/admin123</code>.</p>
                    </div>
                    <div class="col-md-6">
                        <p class="small text-secondary mb-2 fw-bold text-uppercase">Bước 2: Kiểm tra Frontend</p>
                        <p class="small">Nhấn nút <strong>Đăng nhập SSO</strong> ở trên. Nếu SSO hoạt động, bạn sẽ không cần nhập lại mật khẩu.</p>
                    </div>
                </div>
            </div>

            @if (Model != null && ((IEnumerable<WebMvcTestOidc.Data.AuditLog>)Model).Any())
            {
                <div class="card bg-white p-4 text-start border-0 shadow-sm">
                    <h5 class="fw-bold mb-3 text-secondary small text-uppercase"><i class="bi bi-clock-history me-2"></i>Hoạt động gần đây (SQLite)</h5>
                    <div class="list-group list-group-flush">
                        @foreach (var log in (IEnumerable<WebMvcTestOidc.Data.AuditLog>)Model)
                        {
                            <div class="list-group-item px-0 border-0 d-flex justify-content-between align-items-center">
                                <span class="small text-main">@log.Message</span>
                                <span class="badge bg-light text-muted fw-normal" style="font-size: 0.7rem;">@log.Timestamp.ToLocalTime().ToString("HH:mm:ss")</span>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</div>
